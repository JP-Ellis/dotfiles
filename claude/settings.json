{
  "env": {
    "CLAUDE_MODEL": "claude-sonnet-4-6"
  },
  "attribution": {
    "commit": "Assisted-by: Claude Code:{{claude:model}}",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(aube audit *)",
      "Bash(aube ls *)",
      "Bash(aube outdated *)",
      "Bash(aube show *)",
      "Bash(aube test *)",
      "Bash(aube view *)",
      "Bash(biome check *)",
      "Bash(biome ci *)",
      "Bash(biome format *)",
      "Bash(biome lint *)",
      "Bash(cargo +nightly fmt *)",
      "Bash(cargo +nightly miri *)",
      "Bash(cargo add *)",
      "Bash(cargo bench *)",
      "Bash(cargo build *)",
      "Bash(cargo check *)",
      "Bash(cargo clean *)",
      "Bash(cargo clippy *)",
      "Bash(cargo doc *)",
      "Bash(cargo fix *)",
      "Bash(cargo fmt *)",
      "Bash(cargo generate-lockfile *)",
      "Bash(cargo generate *)",
      "Bash(cargo metadata *)",
      "Bash(cargo nextest *)",
      "Bash(cargo remove *)",
      "Bash(cargo run *)",
      "Bash(cargo test *)",
      "Bash(cargo tree *)",
      "Bash(cargo update *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr list *)",
      "Bash(gh pr view *)",
      "Bash(gh run view *)",
      "Bash(git branch *)",
      "Bash(git check-ignore *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git rev-parse *)",
      "Bash(git show *)",
      "Bash(git stash *)",
      "Bash(git status *)",
      "Bash(prek run *)",
      "Bash(ruff check *)",
      "Bash(ruff format *)",
      "Bash(tombi format *)",
      "Bash(tombi lint *)",
      "Bash(uv add *)",
      "Bash(uv build *)",
      "Bash(uv export *)",
      "Bash(uv lock *)",
      "Bash(uv pip *)",
      "Bash(uv python *)",
      "Bash(uv remove *)",
      "Bash(uv run *)",
      "Bash(uv sync *)",
      "Read(~/.claude/plugins/cache/claude-plugins-official/)"
    ],
    "defaultMode": "auto"
  },
  "model": "sonnet",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      }
    ]
  },
  "allowManagedMcpServersOnly": false,
  "enabledPlugins": {
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "effortLevel": "medium",
  "theme": "auto",
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "inputNeededNotifEnabled": true
}
